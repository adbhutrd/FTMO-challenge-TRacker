   "source": [
    "# 🚀 Divine CEO Avatar Generator\n",
    "### Run this on **Google Colab** for FREE GPU (T4 16GB VRAM)\n",
    "\n",
    "No setup needed. Click Runtime → Run All. Takes ~2 minutes."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install dependencies\n",
    "!pip install -q diffusers transformers accelerate xformers gradio"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "from diffusers import StableDiffusionXLPipeline\n",
    "\n",
    "# Load model (SDXL = best quality on free T4 GPU)\n",
    "pipe = StableDiffusionXLPipeline.from_pretrained(\n",
    "    \"stabilityai/stable-diffusion-xl-base-1.0\",\n",
    "    torch_dtype=torch.float16,\n",
    "    variant=\"fp16\",\n",
    "    use_safetensors=True\n",
    ")\n",
    "pipe = pipe.to(\"cuda\")\n",
    "print(\"✅ Model loaded on:\", torch.cuda.get_device_name(0))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate the Divine CEO Avatar\n",
    "prompt = (\n",
    "    \"A divine CEO avatar, golden armor with intricate vedic patterns, \"\n",
    "    \"sitting on a throne of financial charts and trading screens, \"\n",
    "    \"cyberpunk aesthetic, neon purple and gold lighting, \"\n",
    "    \"hyperrealistic 8k, cinematic lighting, detailed face, \"\n",
    "    \"benevolent expression, crown of data streams, \"\n",
    "    \"holographic stock tickers floating around, \"\n",
    "    \"professional yet godlike presence\"\n",
    ")\n",
    "\n",
    "negative = (\n",
    "    \"ugly, blurry, low quality, deformed, extra limbs, \"\n",
    "    \"bad anatomy, watermark, text, signature\"\n",
    ")\n",
    "\n",
    "image = pipe(\n",
    "    prompt=prompt,\n",
    "    negative_prompt=negative,\n",
    "    num_inference_steps=30,\n",
    "    guidance_scale=7.5,\n",
    "    width=768,\n",
    "    height=768,\n",
    ").images[0]\n",
    "\n",
    "image.save(\"divine_ceo_avatar.png\")\n",
    "display(image)\n",
    "print(\"✅ Avatar saved as divine_ceo_avatar.png\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate multiple variations\n",
    "styles = [\n",
    "    \"golden armor, regal pose, stock market background, cinematic\",\n",
    "    "cyberpunk CEO, neon lights, data streams, futuristic throne\",\n",
    "    \"vedic god of wealth, lotus throne, financial prosperity, divine glow\",\n",
    "]\n",
    "\n",
    "for i, style in enumerate(styles):\n",
    "    img = pipe(\n",
    "        prompt=f\"{prompt}, {style}\",\n",
    "        negative_prompt=negative,\n",
    "        num_inference_steps=25,\n",
    "        guidance_scale=7.0,\n",
    "    ).images[0]\n",
    "    img.save(f\"avatar_variant_{i+1}.png\")\n",
    "    display(img)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Launch web UI (optional - use this for custom prompts)\n",
    "import gradio as gr\n",
    "\n",
    "def generate(prompt_text, style_text):\n",
    "    full_prompt = f\"{prompt_text}, {style_text}, 8k, cinematic\"\n",
    "    img = pipe(full_prompt, negative_prompt=negative, \n",
    "              num_inference_steps=25).images[0]\n",
    "    return img\n",
    "\n",
    "iface = gr.Interface(\n",
    "    fn=generate,\n",
    "    inputs=[\n",
    "        gr.Textbox(label=\"Prompt\", lines=2, value=prompt),\n",
    "        gr.Textbox(label=\"Style\", value=\"golden armor, regal\"),\n",
    "    ],\n",
    "    outputs=gr.Image(label=\"Generated Avatar\"),\n",
    "    title=\"🚀 Divine CEO Avatar Generator\",\n",
    "    description=\"Free AI avatar generation running on Colab GPU\"\n",
    ")\n",
    "iface.launch(share=True)  # Gives you a public URL"
   ]
  }
